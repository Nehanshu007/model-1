<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Invitation Card</title>

<style>

    body{
        margin:0;
        padding:0;
        font-family: Arial, sans-serif;
        background: linear-gradient(to right, #ffdde1, #ee9ca7);
    }

    .card{
        width:500px;
        margin:40px auto;
        background:white;
        padding:20px;
        border-radius:15px;
        text-align:center;
        box-shadow:0 0 15px gray;
    }

    h1{
        color:#e91e63;
    }

    h2{
        color:#333;
    }

    p{
        font-size:18px;
    }

    iframe,
    video,
    audio{
        width:100%;
        margin-top:15px;
        border-radius:10px;
    }

</style>
</head>

<body>

<div class="card">

    <h1>🎉 Birthday Invitation 🎉</h1>

    <h2>You Are Invited!</h2>

    <p>
        Join us to celebrate a special birthday party.
    </p>

    <p>
        📅 Date: 25 May 2026 <br>
        ⏰ Time: 7:00 PM <br>
        📍 Venue: Ahmedabad, Gujarat
    </p>

    <!-- AUDIO -->
    <h3>Party Music</h3>

    <audio controls>
        <source src="freesound_community-bit-bit-4-bit-8-bit-36027.mp3" type="audio/mpeg">
        Your browser does not support audio.
    </audio>

    <!-- VIDEO -->
    <h3>Invitation Video</h3>

    <video controls height="250">
        <source src="100_0104.3gp" type="video/mp4">
        Your browser does not support video.
    </video>

    <!-- GOOGLE MAP -->
    <h3>Location Map</h3>

    <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3672.723392579761!2d72.5714!3d23.0225!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x395e84f7c8d2e0df%3A0x8f7f1f5d6d9c3e1!2sAhmedabad!5e0!3m2!1sen!2sin!4v1710000000000!5m2!1sen!2sin"
        height="250"
        style="border:0;"
        allowfullscreen=""
        loading="lazy">
    </iframe>

</div>

</body>
</html>

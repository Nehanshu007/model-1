<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Image Hover & Overlay</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f4f4f4;
      text-align: center;
      padding: 30px;
    }

    /* Image Box */
    .image-box {
      position: relative;
      width: 300px;
      margin: auto;
      overflow: hidden;
      border-radius: 10px;
    }

    .image-box img {
      width: 100%;
      display: block;
      transition: 0.4s;
    }

    /* Zoom Image */
    .image-box:hover img {
      transform: scale(1.2);
    }

    /* Overlay */
    .overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0,0,0,0.6);

      display: flex;
      justify-content: center;
      align-items: center;

      opacity: 0;
      transition: 0.4s;
    }

    /* Show Overlay on Hover */
    .image-box:hover .overlay {
      opacity: 1;
    }

    .txt {
      color: white;
      font-size: 35px;
      font-weight: bold;
    }

    /* Video */
    .video-box {
      margin-top: 40px;
      display: flex;
      justify-content: center;
    }

    video {
      width: 400px;
      border: 4px solid #333;
      border-radius: 10px;
    }

  </style>
</head>
<body>

  <h2>Image Hover Effect</h2>

  <div class="image-box">

    <img src="https://media.cnn.com/api/v1/images/stellar/prod/211227135008-02-the-batman-trailer.jpg?q=h_1406,w_2500,x_0,y_0" alt="">

    <div class="overlay">
      <div class="txt">
        I am vengeance
      </div>
    </div>

  </div>

  <h2>Video Position Example</h2>

  <div class="video-box">
    <video controls>
      <source src="337459_medium.mp4" type="video/mp4">
    </video>
  </div>

</body>
</html>

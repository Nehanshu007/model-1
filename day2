<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Registration Form</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            background-image: url(https://wallpapercave.com/wp/wp5609821.jpg);
            margin: 0;
            padding: 20px;
        }

        header {
            text-align: center;
            margin-bottom: 20px;
            background-color: rgb(255, 208, 0);
            padding: 10px;
        }

        nav {
            cursor: none;
        }

        form {
            background-color: #fdaddd;
            padding: 20px;
            width: 450px;
            margin: auto;
            border-radius: 8px;
            box-shadow: 0 0 10px lightgray;
        }

        fieldset {
            border: 1px solid #ccc;
            padding: 15px;
        }

        legend {
            font-weight: bold;
        }

        label {
            display: inline-block;
            width: 120px;
        }

        input,
        select,
        textarea {
            width: 200px;
            padding: 5px;
            margin-bottom: 10px;
        }

        textarea {
            height: 60px;
        }

        input[type="submit"] {
            width: 100%;
            background-color: #007bff;
            color: white;
            border: none;
            padding: 10px;
            cursor: pointer;
            border-radius: 5px;
        }

        input[type="submit"]:hover {
            background-color: #000000;
        }

        audio,
        video {
            display: block;
            margin: 10px auto;
            width: 100%;
        }

        footer {
            text-align: center;
            margin-top: 20px;
            background-color: rgb(0, 162, 255);
            padding: 10px;
        }
    </style>
</head>

<body>

    <header>
        <h1>Student Registration</h1>

        <nav>
            <a href="#">Home</a>
            <a href="#">About</a>
            <a href="#">Courses</a>
            <a href="#">Contact</a>
        </nav>
    </header>

    <main>
        <section>

            <form action="student_register">

                <fieldset>

                    <legend>Student Details</legend>

                    <label for="name">Name:</label>
                    <input type="text" id="name" name="name" required>
                    <br><br>

                    <label for="enrollment">Enrollment:</label>
                    <input type="text" id="enrollment" name="enrollment">
                    <br><br>

                    <label for="branch">Branch:</label>

                    <select name="branch" id="branch">
                        <option value="">Select Branch</option>
                        <option value="CE">Computer Engineering</option>
                        <option value="CSE">Computer Science Engineering</option>
                        <option value="CS">Computer Science</option>
                        <option value="IT">Information Technology</option>
                        <option value="AIML">AI & ML</option>
                    </select>

                    <br><br>

                    <label for="division">Division:</label>
                    <input type="text" id="division" name="division" maxlength="1">
                    <br><br>

                    <label>Gender:</label>

                    <input type="radio" id="male" name="gender" value="Male">
                    <label for="male">Male</label>

                    <input type="radio" id="female" name="gender" value="Female">
                    <label for="female">Female</label>

                    <br><br>

                    <label for="mobile">Mobile No:</label>
                    <input type="tel" id="mobile" name="mobile" maxlength="10">
                    <br><br>

                    <label for="email">Email:</label>
                    <input type="email" id="email" name="email">
                    <br><br>

                    <label for="password">Password:</label>
                    <input type="password" id="password" name="password">
                    <br><br>

                    <label for="photo">Upload Photo:</label>
                    <input type="file" id="photo" name="photo">
                    <br><br>

                    <label for="time">Date and Time:</label>
                    <input type="datetime-local" id="time">
                    <br><br>

                    <label for="remark">Remark:</label>
                    <textarea id="remark" name="remark"></textarea>

                    <br><br>

                    <!-- AUDIO SECTION -->
                    <h3>Audio</h3>

                    <audio controls>
                        <source src="sample-audio.mp3" type="audio/mpeg">
                        Your browser does not support the audio element.
                    </audio>

                    <br>

                    <!-- VIDEO SECTION -->
                    <h3>Video</h3>

                    <video controls height="250">
                        <source src="sample-video.mp4" type="video/mp4">
                        Your browser does not support the video tag.
                    </video>
<!-- GOOGLE MAP -->
<h3>College Location</h3>

<iframe
    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d29363.902731392773!2d72.53969655!3d23.079231000000014!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x395e833af6f39347%3A0xf1db9065daea7008!2sSilver%20Oak%20University!5e0!3m2!1sen!2sin!4v1778576325765!5m2!1sen!2sin" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
    width="100%"
    height="250"
    style="border:0;"
    allowfullscreen=""
    loading="lazy">
</iframe>

<br><br>

<br><br>
                    <br><br>

                    <input type="submit" value="Register">

                </fieldset>

            </form>

        </section>
    </main>

    <footer>
        <p>&copy; 2026 Student Registration System</p>
    </footer>

</body>
</html>
